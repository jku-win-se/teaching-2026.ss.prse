Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# --- OS: macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- OS: Linux ---
*~
.directory

# --- Java ---
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# --- Maven ---
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# --- IDE: IntelliJ IDEA ---
.idea/
*.iml
*.ipr
*.iws
out/

# --- IDE: Eclipse ---
.classpath
.project
.settings/
bin/

# --- IDE: VS Code ---
.vscode/
!.vscode/settings.json
!.vscode/launch.json

# --- SonarQube ---
.scannerwork/

# --- Docker ---
docker/.env
!docker/.env.example

# --- JaCoCo ---
jacoco.exec

# --- Logs ---
*.log
