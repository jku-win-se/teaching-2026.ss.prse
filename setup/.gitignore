.idea/
*.iml
*.ipr
*.iws
out/

# --- IDE: Eclipse ---
.classpath
.project
.settings/
bin/

# --- IDE: VS Code ---
.vscode/
!.vscode/settings.json
!.vscode/launch.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Java ---
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# --- SonarQube ---
.scannerwork/

# --- Docker ---
docker/.env
!docker/.env.example